{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "description": "DDD-oriented NestJS and Vue application workspace",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.18.0 <21",
    "pnpm": ">=9.15.0 <10"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "dev": "pnpm --parallel --filter @agent/api --filter @agent/web run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --recursive --if-present run lint",
    "prepare": "husky",
    "test": "pnpm --recursive --if-present run test && pnpm --filter @agent/api run test:e2e",
    "typecheck": "pnpm --recursive --if-present run typecheck"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,vue,json,md,yml,yaml,css}": "prettier --write",
    "apps/api/**/*.ts": "pnpm --filter @agent/api exec eslint --fix",
    "apps/web/**/*.{ts,vue}": "pnpm --filter @agent/web exec eslint --fix"
  }
}
