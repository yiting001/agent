NODE_ENV=development
API_PORT=3000
API_SERVICE_NAME=agent-api
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
HTTP_TRUST_PROXY_HOPS=0
DATABASE_URL=postgresql://agent:agent@127.0.0.1:5432/agent
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_MIGRATIONS_RUN=true
DATABASE_SYNCHRONIZE=false
# TEST_DATABASE_URL=postgresql://agent:agent@127.0.0.1:5432/agent_test
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=agent
RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
PUBLIC_CHAT_RATE_LIMIT_MAX=30
CREDENTIAL_ENCRYPTION_KEY=replace-with-64-hexadecimal-characters
DEFAULT_SOFTWARE_NAME=灵枢智能体
BRAND_STORAGE_PATH=brand-storage
BRAND_ICON_MAX_BYTES=1048576
CHAT_ATTACHMENT_STORAGE_PATH=chat-attachments
CHAT_ATTACHMENT_MAX_BYTES=52428800
KNOWLEDGE_STORAGE_PATH=knowledge-storage
KNOWLEDGE_UPLOAD_CHUNK_BYTES=8388608
KNOWLEDGE_MAX_DOCUMENT_BYTES=134217728
KNOWLEDGE_CHUNK_CHARACTERS=1200
KNOWLEDGE_CHUNK_OVERLAP=180
MODEL_REQUEST_TIMEOUT_MS=120000
OBSERVABILITY_RETENTION_DAYS=30
OBSERVABILITY_SLOW_REQUEST_MS=2000
OBSERVABILITY_SLOW_MODEL_MS=30000
OBSERVABILITY_HIGH_COST_USD=0.1
AGENT_MEMORY_RECENT_MESSAGE_LIMIT=12
AGENT_MEMORY_RECALL_LIMIT=6
AGENT_MEMORY_EPISODE_RECALL_LIMIT=3
AGENT_MEMORY_EPISODE_MIN_SCORE=0.25
AGENT_MEMORY_TASK_POLL_INTERVAL_MS=2000
AGENT_MEMORY_TASK_MAX_ATTEMPTS=3
AGENT_MEMORY_TASK_BACKOFF_BASE_MS=1000
AGENT_MEMORY_TASK_LOCK_TIMEOUT_MS=60000
AGENT_MEMORY_PENDING_TIMEOUT_MS=300000
AGENT_MEMORY_RECONCILE_INTERVAL_MS=60000
EMBEDDING_BATCH_SIZE=24
INGESTION_POLL_INTERVAL_MS=2000
INGESTION_MAX_ATTEMPTS=3
INGESTION_BACKOFF_BASE_MS=1000
INGESTION_LOCK_TIMEOUT_MS=300000
VECTOR_HNSW_M=16
VECTOR_HNSW_EF_CONSTRUCTION=64
VECTOR_HNSW_EF_SEARCH=40
